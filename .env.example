# ============================================================
# SupplyMind — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ----------------------------
# Application
# ----------------------------
APP_NAME="SupplyMind"
APP_ENV="development"           # development | staging | production
APP_VERSION="0.1.0"
DEBUG=true
LOG_LEVEL="INFO"                # DEBUG | INFO | WARNING | ERROR

# ----------------------------
# API Server
# ----------------------------
API_HOST="0.0.0.0"
API_PORT=8000
API_PREFIX="/api/v1"
SECRET_KEY="CHANGE_ME_generate_with_openssl_rand_hex_32"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----------------------------
# PostgreSQL Database
# ----------------------------
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="supplymind"
POSTGRES_USER="supplymind_user"
POSTGRES_PASSWORD="CHANGE_ME"
DATABASE_URL="postgresql+asyncpg://supplymind_user:CHANGE_ME@localhost:5432/supplymind"

# ----------------------------
# Redis Cache
# ----------------------------
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL="redis://localhost:6379/0"

# ----------------------------
# MLflow
# ----------------------------
MLFLOW_TRACKING_URI="./mlruns"
MLFLOW_EXPERIMENT_NAME="supplymind"

# ----------------------------
# Kafka (Event Streaming)
# ----------------------------
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
KAFKA_SUPPLIER_TOPIC="supplier.events"
KAFKA_INVENTORY_TOPIC="inventory.alerts"
KAFKA_CONSUMER_GROUP="supplymind-agent"

# ----------------------------
# Agent Configuration
# ----------------------------
AGENT_SCHEDULE_HOUR=3           # Daily trigger hour (UTC)
AGENT_SCHEDULE_MINUTE=0
INVENTORY_POLL_INTERVAL_SECONDS=7200   # 2 hours
EVENT_TRIGGER_OTD_DROP_THRESHOLD=0.15  # 15pp drop triggers event
EVENT_TRIGGER_DEMAND_REVISION=0.40     # 40% revision triggers event

# ----------------------------
# Risk Thresholds
# ----------------------------
RISK_HIGH_THRESHOLD=0.75        # Above this = HIGH risk (LightGBM score)
RISK_CRITICAL_THRESHOLD=0.85    # Above this = CRITICAL
STOCKOUT_WARNING_DAYS=14        # Days-to-stockout alert trigger
AUTONOMOUS_BUDGET_USD=85000     # Max PO value for fully autonomous action
ANOMALY_RECONSTRUCTION_PERCENTILE=95  # LSTM AE threshold percentile

# ----------------------------
# External Data APIs
# ----------------------------
KAGGLE_USERNAME="your_kaggle_username"
KAGGLE_KEY="your_kaggle_api_key"
FRED_API_KEY="your_fred_api_key"    # Get free at fred.stlouisfed.org

# ----------------------------
# Notifications
# ----------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"
MANAGER_EMAIL="manager@yourcompany.com"

# ----------------------------
# Simulated ERP (Mock)
# ----------------------------
ERP_API_URL="http://localhost:8001"   # Mock ERP server
ERP_API_KEY="mock_erp_key_dev"
WMS_API_URL="http://localhost:8002"   # Mock WMS server
WMS_API_KEY="mock_wms_key_dev"
